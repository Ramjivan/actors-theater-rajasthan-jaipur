# ==============================================================================
# ACTORS THEATRE RAJASTHAN — ENVIRONMENT VARIABLES (.env.example)
# ==============================================================================
# Copy this file to `.env` for local development.
# On Cloudflare Pages, add these variables under:
#   Cloudflare Dashboard → Pages Project → Settings → Environment Variables
#
# DO NOT COMMIT YOUR ACTUAL `.env` FILE TO GIT!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. ADMIN CREDENTIALS (for accessing /admin portal)
# ------------------------------------------------------------------------------
# Email and password used by the client/team to log into the /admin photo uploader.
ADMIN_EMAIL="actorsraj@gmail.com"
ADMIN_PASSWORD="ChangeThisToASecurePassword2026!"

# ------------------------------------------------------------------------------
# 2. GITHUB REPOSITORY & AUTHENTICATION TOKEN
# ------------------------------------------------------------------------------
# Format: "owner/repository" (e.g. "your-username/actors-theater-rajasthan-jaipur")
GITHUB_REPO="your-github-username/actors-theater-rajasthan-jaipur"

# Target branch where uploaded photos will be committed (usually "main" or "master")
GITHUB_BRANCH="main"

# Fine-Grained Personal Access Token (PAT) with repository Write permission.
# 
# HOW TO CREATE YOUR GITHUB_TOKEN (Takes 2 minutes):
# 1. Go to: https://github.com/settings/tokens?type=beta
# 2. Click "Generate new token"
# 3. Token name: "ATR Cloudflare Photo Uploader"
# 4. Expiration: 1 year (or custom)
# 5. Repository access: Select "Only select repositories" → choose your ATR repo
# 6. Permissions → Repository permissions:
#      - Contents: Access level = "Read and write"
# 7. Click "Generate token" and copy the `github_pat_...` string below:
GITHUB_TOKEN="github_pat_YOUR_FINE_GRAINED_TOKEN_HERE"
