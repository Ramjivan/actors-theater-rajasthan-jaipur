{
  "name": "atr-astro",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node -e \"const fs=require('fs'); if(fs.existsSync('wrangler.json')) fs.renameSync('wrangler.json','wrangler.tmp')\" && astro build && node -e \"const fs=require('fs'); if(fs.existsSync('wrangler.tmp')) fs.renameSync('wrangler.tmp','wrangler.json')\"",
    "tina-dev": "tinacms dev -c \"astro dev\"",
    "tina-build": "tinacms build && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "start": "serve dist -p ${PORT:-4321}"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@tinacms/cli": "^2.5.6",
    "astro": "^7.0.7",
    "next-auth": "^4.24.15",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "serve": "^14.2.4",
    "tinacms": "^3.11.0",
    "tinacms-authjs": "^24.0.2"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "wrangler": "^4.110.0"
  }
}
