---

<Layout 
  title="Our Activities & Milestones | Actors Theater at Rajasthan" 
  description="Explore the chronological record of Actors Theater at Rajasthan (ATR) theatre workshops, stage performances, street play awareness campaigns, and festival management."
>
  <Navbar />

  <main class="activities-page">
    <div class="container">
      <div class="activities-hero">
        <a href="/" class="back-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
          <span>Back to Home</span>
        </a>
        
        <span class="section-label">Sanstha Milestones</span>
        <h1 class="activities-title">Theatre Activities & Archives</h1>
        <div class="gold-divider"></div>
        <p class="activities-subtitle">
          A comprehensive record of our productions, intensive youth training camps, street play social awareness campaigns, and collaborations spanning 2023 to 2026.
        </p>
      </div>

      <!-- Filters Section -->
      <div class="filters-container">
        <button class="filter-btn active" data-filter="all">All Activities</button>
        <button class="filter-btn" data-filter="stage">Stage Productions</button>
        <button class="filter-btn" data-filter="workshops">Workshops & Camps</button>
        <button class="filter-btn" data-filter="nukkad">Nukkad Natak (Street)</button>
        <button class="filter-btn" data-filter="festivals">Festivals & Judging</button>
      </div>

      <!-- Grid of Activities -->
      <div class="activities-grid">
        {activities.map((act) => (
          <div class="activity-card" data-category={act.category}>
            <div class="activity-images-slider">
              {act.images.map((img) => (
                <div class="slide-img-wrap">
                  <img src={img} alt={act.title} loading="lazy" class="gallery-trigger" />
                </div>
              ))}
            </div>
            
            <div class="activity-details">
              <div class="activity-meta">
                <span class="activity-date">{act.date}</span>
                <span class="activity-category-badge">{act.category}</span>
              </div>
              <h2 class="activity-title">{act.title}</h2>
              <div class="activity-venue">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16">
                  <path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <span>{act.venue}</span>
              </div>
              <p class="activity-desc">{act.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>

  <!-- Image Lightbox Modal -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close" aria-label="Close image">×</button>
    <button class="lightbox-nav prev" id="lightbox-prev" aria-label="Previous image">‹</button>
    <img class="lightbox-content" id="lightbox-img" alt="Enlarged gallery photo" />
    <button class="lightbox-nav next" id="lightbox-next" aria-label="Next image">›</button>
  </div>

  <Footer />
</Layout>

<style>
  .activities-page {
    padding-top: 8rem;
    padding-bottom: 6rem;
    background: var(--bg-body);
  }

  .activities-hero {
    max-width: 700px;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--saffron);
    margin-bottom: 2rem;
    transition: var(--transition);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--saffron-deep);
    transform: translateX(-4px);
  }

  .activities-title {
    font-size: clamp(2.5rem, 5vw, 3.8rem);
    color: var(--ink);
    line-height: 1.1;
    margin-top: 0.5rem;
  }

  .activities-hero .gold-divider {
    margin: 1.5rem 0;
  }

  .activities-subtitle {
    font-size: 1.05rem;
    color: var(--ink-body);
    line-height: 1.85;
  }

  /* Filters styling */
  .filters-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 3.5rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1.5rem;
  }

  .filter-btn {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.6rem 1.2rem;
    border-radius: 30px;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--ink-body);
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .filter-btn:hover {
    border-color: var(--saffron);
    color: var(--saffron);
  }

  .filter-btn.active {
    background: var(--saffron);
    border-color: var(--saffron);
    color: #FFFFFF;
    box-shadow: 0 4px 12px rgba(232, 114, 12, 0.25);
  }

  /* Grid Layout */
  .activities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2.5rem;
  }

  .activity-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .activity-card.hidden {
    display: none;
  }

  /* Images Slider/Gallery styling */
  .activity-images-slider {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    background: #000000;
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
  }

  .activity-images-slider::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .slide-img-wrap {
    flex: 0 0 100%;
    width: 100%;
    scroll-snap-align: start;
    position: relative;
    cursor: zoom-in;
  }

  .slide-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .slide-img-wrap:hover img {
    transform: scale(1.04);
  }

  /* Details styling */
  .activity-details {
    padding: 1.8rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .activity-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.8rem;
  }

  .activity-date {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--saffron);
  }

  .activity-category-badge {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    background: rgba(201, 168, 76, 0.12);
    color: var(--gold);
  }

  .activity-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.3;
    margin-bottom: 0.8rem;
    font-family: 'Playfair Display', serif;
  }

  .activity-venue {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: var(--ink-body);
    margin-bottom: 1rem;
    opacity: 0.85;
  }

  .activity-venue svg {
    color: var(--saffron);
    flex-shrink: 0;
  }

  .activity-desc {
    font-size: 0.9rem;
    color: var(--ink-body);
    line-height: 1.65;
  }

  /* Lightbox Styles */
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(26, 24, 22, 0.96);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .lightbox.active {
    display: flex;
  }

  .lightbox-content {
    max-width: 90%;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
  }

  .lightbox-close {
    position: absolute;
    top: 2rem;
    right: 2rem;
    background: none;
    border: none;
    color: #FFFFFF;
    font-size: 3rem;
    cursor: pointer;
    line-height: 0.5;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .lightbox-close:hover {
    opacity: 1;
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.4);
    border: none;
    color: #FFFFFF;
    font-size: 3.5rem;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.6;
    transition: opacity 0.2s ease, background-color 0.2s ease;
  }

  .lightbox-nav:hover {
    opacity: 1;
    background: rgba(0, 0, 0, 0.7);
  }

  .lightbox-nav.prev { left: 2rem; }
  .lightbox-nav.next { right: 2rem; }

  @media (max-width: 768px) {
    .activities-grid {
      grid-template-columns: 1fr;
    }
    .lightbox-nav {
      width: 44px;
      height: 44px;
      font-size: 2.5rem;
    }
  }
</style>

<script>
  // Filter functionality
  const filterButtons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.activity-card');

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Remove active class from all buttons
      filterButtons.forEach(b => b.classList.remove('active'));
      // Add active to clicked button
      btn.classList.add('active');

      const filterValue = btn.getAttribute('data-filter');

      cards.forEach(card => {
        const category = card.getAttribute('data-category');
        if (filterValue === 'all' || category === filterValue) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });

  // Lightbox functionality
  const triggers = document.querySelectorAll('.gallery-trigger');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.getElementById('lightbox-close');
  const prevBtn = document.getElementById('lightbox-prev');
  const nextBtn = document.getElementById('lightbox-next');

  let currentImagesList: string[] = [];
  let currentIndex = 0;

  // Gather all unique image paths currently displayed on the page
  function updateImagesList() {
    currentImagesList = [];
    const visibleTriggers = document.querySelectorAll('.activity-card:not(.hidden) .gallery-trigger');
    visibleTriggers.forEach(img => {
      const src = img.getAttribute('src');
      if (src && !currentImagesList.includes(src)) {
        currentImagesList.push(src);
      }
    });
  }

  triggers.forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      const target = e.target as HTMLImageElement;
      updateImagesList();
      const currentSrc = target.getAttribute('src');
      if (currentSrc) {
        currentIndex = currentImagesList.indexOf(currentSrc);
        openLightbox();
      }
    });
  });

  function openLightbox() {
    if (lightboxImg && currentImagesList[currentIndex]) {
      lightboxImg.src = currentImagesList[currentIndex];
      lightbox?.classList.add('active');
      document.body.style.overflow = 'hidden'; // Prevent background scrolling
    }
  }

  function closeLightbox() {
    lightbox?.classList.remove('active');
    document.body.style.overflow = '';
  }

  closeBtn?.addEventListener('click', closeLightbox);

  prevBtn?.addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + currentImagesList.length) % currentImagesList.length;
    if (lightboxImg) lightboxImg.src = currentImagesList[currentIndex];
  });

  nextBtn?.addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % currentImagesList.length;
    if (lightboxImg) lightboxImg.src = currentImagesList[currentIndex];
  });

  // Close when clicking outside of image
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      closeLightbox();
    }
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') prevBtn?.click();
    if (e.key === 'ArrowRight') nextBtn?.click();
  });
</script>
