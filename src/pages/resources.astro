---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const resources = [
  {
    title: "Actors THR Activities Last 3 Years 2021 to 2026",
    filename: "Activities_Report_2021_2026.pdf",
    path: "/documents/Activities_Report_2021_2026.pdf",
    size: "78.8 MB",
    type: "PDF Document",
    description: "Our complete official activities report detailing stage performances, street play campaigns, collaborations with the Sangeet Natak Akademi, and youth theatre workshops across Rajasthan from 2021 to 2026.",
    accent: "#E8720C"
  },
  {
    title: "Rangmanch Smarika 2026",
    filename: "Rangmanch_Smarika_2026.pdf",
    path: "/documents/Rangmanch_Smarika_2026.pdf",
    size: "69.2 MB",
    type: "PDF Document",
    description: "The 2026 commemorative souvenir booklet containing messages from state and national cultural heads, essays on traditional folk drama forms, signature repertoire descriptions, and archive highlights.",
    accent: "#D4880A"
  },
  {
    title: "Kalpurush Play Brochure",
    filename: "Kalpurush_Play_Brochure.pdf",
    path: "/documents/Kalpurush_Play_Brochure.pdf",
    size: "4.1 MB",
    type: "PDF Brochure",
    description: "Official play brochure and cast sheet for 'Kalpurush' (Krantikari Veer Savarkar), including script synopsis, production design notes, research references, and the full list of cast and crew members.",
    accent: "#8E44AD"
  }
];
---

<Layout 
  title="Publications & Resources | Actors Theatre Rajasthan" 
  description="Download official activities reports, souvenirs, brochures, and publications from the Actors Theatre Rajasthan archives."
>
  <Navbar />

  <main class="resources-page">
    <div class="container">
      <div class="resources-hero">
        <a href="/" class="back-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
          <span>Back to Home</span>
        </a>
        
        <span class="section-label">Official Publications</span>
        <h1 class="resources-title">Resource Library & Archives</h1>
        <div class="gold-divider"></div>
        <p class="resources-subtitle">
          Access and download our official program books, commemorative publications, and activities archives. 
          All documents are available as high-resolution PDF publications.
        </p>
      </div>

      <!-- Resource Grid -->
      <div class="resources-grid">
        {resources.map((resource) => (
          <div class="resource-card">
            <div class="card-glow" style={`background: radial-gradient(circle at 10% 10%, ${resource.accent}12, transparent 50%);`}></div>
            <div class="resource-info">
              <div class="file-badge">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                  <polyline points="10 9 9 9 8 9"/>
                </svg>
                <span>{resource.type}</span>
              </div>
              
              <h2>{resource.title}</h2>
              <p class="resource-desc">{resource.description}</p>
              
              <div class="metadata-row">
                <div class="meta-item">
                  <span class="meta-label">File Name:</span>
                  <span class="meta-val font-mono">{resource.filename}</span>
                </div>
                <div class="meta-item">
                  <span class="meta-label">File Size:</span>
                  <span class="meta-val">{resource.size}</span>
                </div>
              </div>
            </div>
            
            <a 
              href={resource.path} 
              download={resource.filename} 
              class="download-btn"
              style={`border-color: ${resource.accent}; color: ${resource.accent};`}
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              <span>Download Publication</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .resources-page {
    padding-top: 8rem;
    padding-bottom: 6rem;
    background: var(--bg-body);
  }

  .resources-hero {
    max-width: 700px;
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--saffron);
    margin-bottom: 2rem;
    transition: var(--transition);
  }

  .back-link:hover {
    color: var(--saffron-deep);
    transform: translateX(-4px);
  }

  .resources-title {
    font-size: clamp(2.5rem, 5vw, 3.8rem);
    color: var(--ink);
    line-height: 1.1;
    margin-top: 0.5rem;
  }

  .resources-hero .gold-divider {
    margin: 1.5rem 0;
  }

  .resources-subtitle {
    font-size: 1.05rem;
    color: var(--ink-body);
    line-height: 1.85;
  }

  /* Grid Layout */
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 2.5rem;
  }

  .resource-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2.2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
    overflow: hidden;
  }

  .card-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .resource-info {
    position: relative;
    z-index: 1;
  }

  .file-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--saffron);
    margin-bottom: 1.25rem;
  }

  .resource-card h2 {
    font-size: 1.4rem;
    color: var(--ink);
    margin-bottom: 1rem;
    font-family: 'Playfair Display', serif;
  }

  .resource-desc {
    font-size: 0.88rem;
    color: var(--ink-body);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .metadata-row {
    border-top: 1px dashed var(--border);
    padding-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .meta-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
  }

  .meta-label {
    color: var(--ink-muted);
  }

  .meta-val {
    font-weight: 600;
    color: var(--ink-body);
  }

  .font-mono {
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.75rem;
    word-break: break-all;
    max-width: 70%;
    text-align: right;
  }

  .download-btn {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    border: 1.5px solid;
    padding: 0.8rem 1.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    border-radius: 4px;
    background: transparent;
    transition: var(--transition);
    cursor: pointer;
    text-align: center;
  }

  .download-btn:hover {
    background: var(--saffron);
    color: #FFFFFF !important;
    border-color: var(--saffron) !important;
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(232, 114, 12, 0.15);
  }

  .resource-card:hover {
    transform: translateY(-5px);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 768px) {
    .resources-page { padding-top: 6.5rem; }
    .resource-card { padding: 1.75rem; }
  }
</style>
