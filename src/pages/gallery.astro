---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const galleryDir = path.resolve(__dirname, '../../public/images/gallery');
const files = fs.existsSync(galleryDir) ? fs.readdirSync(galleryDir) : [];

const galleryImages = files
  .filter(file => /\.(png|jpe?g|webp)$/i.test(file))
  .map(file => `/images/gallery/${file}`);

// Fallback if directory is empty (add default performance images)
const fallbackImages = [
  "/images/events/traditional_performance_stage.jpeg",
  "/images/events/patriotic_performance_stage.jpeg",
  "/images/events/rehearsal_workshop.jpeg",
  "/images/events/school_workshop_outdoor_1.jpeg",
  "/images/events/school_workshop_outdoor_2.jpeg",
  "/images/events/rajrangam_musical_performance.jpeg",
  "/images/events/masked_theatre_performance.jpeg"
];

const allImages = [...galleryImages, ...fallbackImages];
---

<Layout 
  title="Photo Gallery | Actors Theater at Rajasthan" 
  description="Explore moments of live plays, children theatre workshops, street play campaigns and cultural events organized by Actors Theater at Rajasthan."
>
  <Navbar />

  <main class="gallery-page">
    <div class="container">
      <div class="gallery-hero">
        <a href="/" class="back-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
          <span>Back to Home</span>
        </a>
        
        <span class="section-label">Visual Archives</span>
        <h1 class="gallery-title">Photo Gallery</h1>
        <div class="gold-divider"></div>
        <p class="gallery-subtitle">
          Capturing the spirit of live stage plays, interactive classroom workshops, street plays, and cultural events across Rajasthan.
        </p>
      </div>

      <!-- Gallery Grid -->
      <div class="gallery-grid" id="gallery-grid">
        {allImages.map((src, index) => (
          <div 
            class="gallery-item animate-in" 
            data-src={src} 
            data-index={index}
          >
            <div class="image-card">
              <img src={src} alt={`Gallery Image ${index + 1}`} loading="lazy" />
              <div class="image-overlay">
                <span class="zoom-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="18" height="18">
                    <circle cx="11" cy="11" r="8"/>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    <line x1="11" y1="8" x2="11" y2="14"/>
                    <line x1="8" y1="11" x2="14" y2="11"/>
                  </svg>
                </span>
                <span>Zoom Photo</span>
              </div>
            </div>
            <div class="image-caption">Theatre Production Image #{index + 1}</div>
          </div>
        ))}
      </div>
    </div>
  </main>

  <!-- Interactive Lightbox Modal -->
  <div id="gallery-lightbox" class="lightbox">
    <button class="lightbox-close" id="close-lightbox" aria-label="Close gallery">×</button>
    <button class="lightbox-nav prev" id="prev-lightbox" aria-label="Previous image">‹</button>
    <div class="lightbox-wrapper">
      <img id="lightbox-img" src="" alt="Expanded gallery photo" />
      <div class="lightbox-caption">
        <h3 id="lightbox-title"></h3>
      </div>
    </div>
    <button class="lightbox-nav next" id="next-lightbox" aria-label="Next image">›</button>
  </div>

  <Footer />
</Layout>

<style>
  .gallery-page {
    padding-top: 8rem;
    padding-bottom: 6rem;
    background: var(--bg-body);
  }

  .gallery-hero {
    max-width: 700px;
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--saffron);
    margin-bottom: 2rem;
    transition: var(--transition);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--saffron-deep);
    transform: translateX(-4px);
  }

  .gallery-title {
    font-size: clamp(2.5rem, 5vw, 3.8rem);
    color: var(--ink);
    line-height: 1.1;
    margin-top: 0.5rem;
  }

  .gallery-hero .gold-divider {
    margin: 1.5rem 0;
  }

  .gallery-subtitle {
    font-size: 1.05rem;
    color: var(--ink-body);
    line-height: 1.85;
  }

  /* Grid Layout */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2.5rem;
  }

  .gallery-item {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .image-card {
    position: relative;
    border-radius: 8px;
    border: 1px solid var(--border);
    aspect-ratio: 4/3;
    overflow: hidden;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
    background: #000000;
  }

  .image-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .image-card:hover img {
    transform: scale(1.05);
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: rgba(44, 24, 0, 0.85);
    backdrop-filter: blur(4px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: #FFFFFF;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .image-card:hover .image-overlay {
    opacity: 1;
  }

  .zoom-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--saffron);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
  }

  .image-caption {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink-body);
    opacity: 0.8;
  }

  /* Lightbox Styles */
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(26, 24, 22, 0.97);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .lightbox.active {
    display: flex;
  }

  .lightbox-wrapper {
    position: relative;
    max-width: 85%;
    max-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #lightbox-img {
    max-width: 100%;
    max-height: 72vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.5);
  }

  .lightbox-caption {
    margin-top: 1.25rem;
    text-align: center;
    color: #FFFFFF;
  }

  .lightbox-caption h3 {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--ivory);
    font-family: 'Playfair Display', serif;
  }

  .lightbox-close {
    position: absolute;
    top: 2rem;
    right: 2rem;
    background: none;
    border: none;
    color: #FFFFFF;
    font-size: 3rem;
    cursor: pointer;
    line-height: 0.5;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .lightbox-close:hover {
    opacity: 1;
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0,0,0,0.4);
    border: none;
    color: #FFFFFF;
    font-size: 3.5rem;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.6;
    transition: opacity 0.2s ease, background-color 0.2s ease;
    z-index: 1010;
  }

  .lightbox-nav:hover {
    opacity: 1;
    background: rgba(0,0,0,0.7);
  }

  .lightbox-nav.prev { left: 2rem; }
  .lightbox-nav.next { right: 2rem; }

  @media (max-width: 768px) {
    .lightbox-nav {
      width: 44px;
      height: 44px;
      font-size: 2.5rem;
    }
    .lightbox-nav.prev { left: 0.5rem; }
    .lightbox-nav.next { right: 0.5rem; }
  }
</style>

<script>
  const items = document.querySelectorAll('.gallery-item');
  const lightbox = document.getElementById('gallery-lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxTitle = document.getElementById('lightbox-title');
  const closeBtn = document.getElementById('close-lightbox');
  const prevBtn = document.getElementById('prev-lightbox');
  const nextBtn = document.getElementById('next-lightbox');

  let currentIndex = 0;

  function openLightbox(index: number) {
    const item = items[index];
    if (!item) return;

    const src = item.getAttribute('data-src');
    if (src && lightboxImg) {
      currentIndex = index;
      lightboxImg.src = src;
      if (lightboxTitle) {
        lightboxTitle.textContent = `Production & Performance Image #${index + 1}`;
      }
      lightbox?.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeLightbox() {
    lightbox?.classList.remove('active');
    document.body.style.overflow = '';
    if (lightboxImg) lightboxImg.src = '';
  }

  items.forEach((item, idx) => {
    item.addEventListener('click', () => openLightbox(idx));
  });

  closeBtn?.addEventListener('click', closeLightbox);

  prevBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    let prevIndex = currentIndex - 1;
    if (prevIndex < 0) prevIndex = items.length - 1;
    openLightbox(prevIndex);
  });

  nextBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    let nextIndex = currentIndex + 1;
    if (nextIndex >= items.length) nextIndex = 0;
    openLightbox(nextIndex);
  });

  // Close when clicking background outside card wrapper
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      closeLightbox();
    }
  });

  // Keyboard navigation
  window.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('active')) return;

    if (e.key === 'Escape') {
      closeLightbox();
    } else if (e.key === 'ArrowLeft') {
      let prevIndex = currentIndex - 1;
      if (prevIndex < 0) prevIndex = items.length - 1;
      openLightbox(prevIndex);
    } else if (e.key === 'ArrowRight') {
      let nextIndex = currentIndex + 1;
      if (nextIndex >= items.length) nextIndex = 0;
      openLightbox(nextIndex);
    }
  });
</script>
