---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Donate & Support | Actors Theatre Rajasthan" 
  description="Support Actors Theatre Rajasthan. Your contributions help us preserve cultural heritage and illuminate social issues through theatre. All donations are exempt under section 80G and 12A."
>
  <Navbar />
  
  <main class="donate-page">
    <div class="container">
      <!-- Header / Hero -->
      <div class="donate-hero">
        <div class="back-link-box">
          <a href="/" class="back-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
              <line x1="19" y1="12" x2="5" y2="12"/>
              <polyline points="12 19 5 12 12 5"/>
            </svg>
            <span>Back to Home</span>
          </a>
        </div>
        
        <span class="section-label">Support & Donations</span>
        <h1 class="donate-title">Support Actors Theatre Rajasthan</h1>
        <div class="gold-divider"></div>
        <p class="donate-subtitle">
          Your contributions fuel free social theatre, youth workshops, and folk art preservation across Rajasthan. All donations are tax-exempt under sections 12A & 80G.
        </p>
      </div>

      <!-- Main Content Grid -->
      <div class="donate-grid">
        
        <!-- Bank Details Card (Primary) -->
        <div class="donate-card bank-card">
          <div class="card-header">
            <div class="card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="6" width="20" height="12" rx="2"></rect>
                <circle cx="12" cy="12" r="2"></circle>
                <path d="M6 12h.01M18 12h.01"></path>
              </svg>
            </div>
            <div>
              <h2>Bank Account Details</h2>
              <p class="card-desc">Transfer via NEFT, RTGS, IMPS, or UPI</p>
            </div>
          </div>

          <div class="bank-details-list">
            <div class="bank-item">
              <span class="bank-label">Account Name</span>
              <span class="bank-value highlight">ACTORS THEATRE AT RAJASTHAN</span>
            </div>

            <div class="bank-item">
              <span class="bank-label">Bank Name</span>
              <span class="bank-value">AU Small Finance Bank</span>
            </div>

            <div class="bank-item">
              <span class="bank-label">Account Number</span>
              <div class="bank-value-group">
                <span class="bank-value mono">2081221528671018</span>
                <button class="copy-btn" onclick="copyText('2081221528671018', this)" title="Copy Account Number">
                  Copy
                </button>
              </div>
            </div>

            <div class="bank-item">
              <span class="bank-label">IFSC Code</span>
              <div class="bank-value-group">
                <span class="bank-value mono">AUBL0002215</span>
                <button class="copy-btn" onclick="copyText('AUBL0002215', this)" title="Copy IFSC Code">
                  Copy
                </button>
              </div>
            </div>

            <div class="bank-item">
              <span class="bank-label">SWIFT Code (Intl)</span>
              <span class="bank-value mono">AUBLINBBXXX</span>
            </div>

            <div class="bank-item">
              <span class="bank-label">Branch</span>
              <span class="bank-value">Gopalpura Bypass Jaipur</span>
            </div>
          </div>
        </div>

        <!-- Tax Benefits Card -->
        <div class="donate-card tax-card">
          <div class="card-header">
            <div class="card-icon gold">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
            </div>
            <div>
              <h2>Tax Exemptions (80G & 12A)</h2>
              <p class="card-desc">Tax Benefits for Donors</p>
            </div>
          </div>

          <div class="tax-benefits-body">
            <div class="tax-badge-row">
              <span class="tax-pill">Section 80G Certified</span>
              <span class="tax-pill">Section 12A Registered</span>
            </div>

            <p class="tax-info-text">
              All contributions made to <strong>Actors Theatre Rajasthan</strong> are eligible for a 
              <strong>50% Tax Exemption</strong> under Section 80G of the Indian Income Tax Act.
            </p>

            <div class="registration-box">
              <div class="reg-row">
                <span class="reg-label">NGO Darpan ID</span>
                <span class="reg-val">RJ/2010/0031456</span>
              </div>
              <div class="reg-row">
                <span class="reg-label">FCRA Reg. No.</span>
                <span class="reg-val">125560336</span>
              </div>
              <div class="reg-row">
                <span class="reg-label">Organisation Status</span>
                <span class="reg-val">Registered Non-Governmental Society</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Receipt Request (Full Width) -->
        <div class="donate-card receipt-card full-width">
          <div class="receipt-content">
            <div class="receipt-badge">80G Receipt</div>
            <h2>How to Receive Your Tax Exemption Receipt</h2>
            <p>
              After making your transfer, please send a screenshot/slip of your payment along with your 
              <strong>Full Name</strong>, <strong>PAN Card Number</strong>, and <strong>Address</strong> to our team on WhatsApp. We will issue and send your official 80G tax receipt.
            </p>
            <a 
              href="https://wa.me/917821844466?text=Hello%20ATR%20Team%2C%20I%20have%20made%20a%20donation.%20Here%20is%20my%20transaction%20slip%20and%20PAN%20details%20for%2080G%20receipt." 
              class="btn-whatsapp" 
              target="_blank" 
              rel="noopener"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Send Payment Slip on WhatsApp
            </a>
          </div>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script is:inline>
  function copyText(str, btn) {
    navigator.clipboard.writeText(str).then(function() {
      const orig = btn.innerText;
      btn.innerText = 'Copied!';
      btn.style.background = '#25D366';
      btn.style.color = '#FFFFFF';
      setTimeout(function() {
        btn.innerText = orig;
        btn.style.background = '';
        btn.style.color = '';
      }, 2000);
    });
  }
</script>

<style>
  .donate-page {
    background-color: var(--bg-body);
    color: var(--ink-body);
    padding-top: 100px;
    padding-bottom: 5rem;
    min-height: 100vh;
  }

  .back-link-box {
    margin-bottom: 1.25rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--saffron);
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition);
  }

  .back-link:hover {
    color: var(--saffron-deep);
    transform: translateX(-4px);
  }

  .donate-hero {
    margin-bottom: 3rem;
  }

  .donate-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    color: var(--ink);
    margin-top: 0.5rem;
    margin-bottom: 1rem;
  }

  .donate-subtitle {
    font-size: 1.05rem;
    color: var(--ink-body);
    max-width: 680px;
    line-height: 1.8;
  }

  /* Donate Grid */
  .donate-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .donate-card {
    background: #FFFFFF;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2.25rem;
    box-shadow: var(--shadow-md);
  }

  .donate-card.full-width {
    grid-column: 1 / -1;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(232, 114, 12, 0.12);
  }

  .card-icon {
    width: 48px;
    height: 48px;
    background: rgba(232, 114, 12, 0.1);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--saffron);
    flex-shrink: 0;
  }

  .card-icon.gold {
    background: rgba(212, 136, 10, 0.1);
    color: var(--amber);
  }

  .card-header h2 {
    font-size: 1.35rem;
    color: var(--ink);
    margin-bottom: 0.2rem;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--ink-muted);
  }

  /* Bank Details List */
  .bank-details-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .bank-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 0.85rem;
    border-bottom: 1px dashed rgba(232, 114, 12, 0.15);
  }

  .bank-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .bank-label {
    font-size: 0.88rem;
    color: var(--ink-muted);
    font-weight: 500;
  }

  .bank-value {
    font-size: 0.95rem;
    color: var(--ink);
    font-weight: 600;
    text-align: right;
  }

  .bank-value.highlight {
    color: var(--saffron-deep);
    font-weight: 700;
  }

  .bank-value.mono {
    font-family: 'Inter', monospace;
    letter-spacing: 0.04em;
  }

  .bank-value-group {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .copy-btn {
    background: rgba(232, 114, 12, 0.1);
    border: 1px solid var(--border-strong);
    color: var(--saffron-deep);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.65rem;
    border-radius: 4px;
    cursor: pointer;
    transition: var(--transition);
  }

  .copy-btn:hover {
    background: var(--saffron);
    color: #FFFFFF;
  }

  /* Tax Card */
  .tax-badge-row {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .tax-pill {
    background: var(--bg-warm);
    border: 1px solid var(--border-strong);
    color: var(--saffron-deep);
    font-size: 0.8rem;
    font-weight: 700;
    padding: 0.4rem 0.85rem;
    border-radius: 20px;
  }

  .tax-info-text {
    font-size: 0.95rem;
    color: var(--ink-body);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .registration-box {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .reg-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
  }

  .reg-label {
    color: var(--ink-muted);
  }

  .reg-val {
    color: var(--ink);
    font-weight: 600;
    font-family: 'Inter', monospace;
  }

  /* Receipt Card */
  .receipt-card {
    background: linear-gradient(135deg, #FFFDF7 0%, #FFF8EE 100%);
    border: 1px solid var(--border-strong);
    position: relative;
    overflow: hidden;
  }

  .receipt-badge {
    display: inline-block;
    background: #25D366;
    color: #FFFFFF;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.35rem 0.85rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .receipt-content h2 {
    font-size: 1.5rem;
    color: var(--ink);
    margin-bottom: 0.6rem;
  }

  .receipt-content p {
    font-size: 0.95rem;
    color: var(--ink-body);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 800px;
  }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #25D366;
    color: #FFFFFF;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.85rem 1.75rem;
    border-radius: 6px;
    text-decoration: none;
    transition: var(--transition);
    box-shadow: 0 4px 14px rgba(37, 211, 102, 0.25);
  }

  .btn-whatsapp:hover {
    background: #1da851;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.35);
  }

  @media (max-width: 768px) {
    .donate-grid { grid-template-columns: 1fr; }
    .bank-item { flex-direction: column; align-items: flex-start; gap: 0.3rem; }
    .bank-value, .bank-value-group { text-align: left; }
    .reg-row { flex-direction: column; gap: 0.2rem; }
  }
</style>
