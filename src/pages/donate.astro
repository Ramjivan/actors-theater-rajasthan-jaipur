---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Donate & Support | Actors Theatre Rajasthan" 
  description="Support Actors Theatre Rajasthan. Your contributions help us preserve cultural heritage and illuminate social issues through theatre. All donations are exempt under section 80G and 12A."
>
  <Navbar />
  
  <main class="page-main">
    <section class="donate-header">
      <div class="container">
        <h1 class="page-title animate-in">Support the Arts</h1>
        <p class="page-subtitle animate-in" style="animation-delay: 0.1s">
          Your contributions help us sustain theatrical excellence, train the next generation of artists, and bring transformative stories to our community.
        </p>
      </div>
    </section>

    <section class="donate-content">
      <div class="container">
        <div class="donate-grid">
          
          <div class="donate-info-card animate-in" style="animation-delay: 0.2s">
            <div class="tax-badge">Tax Exempt</div>
            <h2>Tax Benefits</h2>
            <p>
              Actors Theatre Rajasthan is a registered non-governmental organisation. 
              <strong>All donations made to our organisation are eligible for tax exemption under sections 12A and 80G of the Income Tax Act.</strong>
            </p>
            <div class="tax-icons">
              <span class="tax-tag">12A Registered</span>
              <span class="tax-tag">80G Certified</span>
            </div>
          </div>

          <div class="donate-info-card animate-in" style="animation-delay: 0.3s">
            <h2>Bank Transfer Details</h2>
            <p>You can directly transfer your contribution to our official bank account via NEFT, RTGS, IMPS, or UPI.</p>
            
            <div class="bank-details-box">
              <div class="bank-row">
                <span class="bank-label">Account Name:</span>
                <span class="bank-value">ACTORS THEATRE @ RAJASTHAN FCRA</span>
              </div>
              <div class="bank-row">
                <span class="bank-label">Bank Name:</span>
                <span class="bank-value">Axis Bank Ltd</span>
              </div>
              <div class="bank-row">
                <span class="bank-label">Account Number:</span>
                <span class="bank-value">920010051233347</span>
              </div>
              <div class="bank-row">
                <span class="bank-label">IFSC Code:</span>
                <span class="bank-value">UTIB0004332</span>
              </div>
              <div class="bank-row">
                <span class="bank-label">SWIFT Code:</span>
                <span class="bank-value">AXISINBBXXX</span>
              </div>
              <div class="bank-row">
                <span class="bank-label">Branch:</span>
                <span class="bank-value">Barkat Nagar, Jaipur</span>
              </div>
            </div>
          </div>

          <div class="donate-info-card full-width animate-in" style="animation-delay: 0.4s">
            <div class="receipt-section">
              <div class="receipt-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                  <line x1="16" y1="13" x2="8" y2="13"></line>
                  <line x1="16" y1="17" x2="8" y2="17"></line>
                  <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
              </div>
              <div class="receipt-content">
                <h2>Get Your Donation Receipt</h2>
                <p>
                  To receive your official 80G tax exemption receipt, please send us a screenshot/slip of your successful transaction on WhatsApp along with your Full Name, PAN Card Number, and Address.
                </p>
                <a href="https://wa.me/917821844466?text=Hello,%20I%20have%20made%20a%20donation.%20Here%20is%20my%20transaction%20slip." class="btn btn-whatsapp" target="_blank" rel="noopener">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  Send Slip on WhatsApp
                </a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-main {
    padding-top: 100px;
    min-height: 100vh;
    background: var(--bg-color);
  }

  .donate-header {
    text-align: center;
    padding: 6rem 0 3rem;
  }

  .page-title {
    font-family: 'Playfair Display', serif;
    font-size: 3.5rem;
    color: var(--ivory);
    margin-bottom: 1rem;
    position: relative;
    display: inline-block;
  }

  .page-title::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 2px;
    background: var(--gold);
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: rgba(255, 248, 230, 0.7);
    max-width: 600px;
    margin: 1.5rem auto 0;
    line-height: 1.8;
  }

  .donate-content {
    padding-bottom: 6rem;
  }

  .donate-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .donate-info-card {
    background: var(--surface-light);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 2.5rem;
    position: relative;
  }

  .donate-info-card.full-width {
    grid-column: 1 / -1;
  }

  .tax-badge {
    position: absolute;
    top: -12px;
    right: 24px;
    background: var(--gold);
    color: var(--charcoal);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.35rem 1rem;
    border-radius: 20px;
    box-shadow: 0 4px 12px rgba(201, 168, 76, 0.3);
  }

  .donate-info-card h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: var(--saffron-light);
    margin-bottom: 1rem;
  }

  .donate-info-card p {
    font-size: 0.95rem;
    color: rgba(255, 248, 230, 0.8);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .donate-info-card p strong {
    color: var(--ivory);
  }

  .tax-icons {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .tax-tag {
    background: rgba(201, 168, 76, 0.1);
    color: var(--gold);
    border: 1px solid rgba(201, 168, 76, 0.2);
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .bank-details-box {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .bank-row {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px dashed rgba(255, 255, 255, 0.08);
    padding-bottom: 0.75rem;
  }

  .bank-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .bank-label {
    color: rgba(255, 248, 230, 0.5);
    font-size: 0.9rem;
  }

  .bank-value {
    color: var(--ivory);
    font-weight: 500;
    font-family: 'Inter', monospace;
    font-size: 0.95rem;
    text-align: right;
  }

  .receipt-section {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .receipt-icon {
    width: 80px;
    height: 80px;
    background: rgba(201, 168, 76, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    flex-shrink: 0;
  }

  .receipt-content h2 {
    margin-bottom: 0.5rem;
  }

  .receipt-content p {
    margin-bottom: 1.25rem;
  }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #25D366;
    color: #fff;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-whatsapp:hover {
    background: #1da851;
    transform: translateY(-2px);
  }

  /* Animations */
  .animate-in {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .donate-grid {
      grid-template-columns: 1fr;
    }
    .receipt-section {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
    }
    .page-title {
      font-size: 2.5rem;
    }
  }
</style>
