---

<section class="contact section" id="contact">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info animate-in">
        <span class="section-label">Get in Touch</span>
        <h2 class="section-title">Join the Movement.<br />Support the Arts.</h2>
        <div class="gold-divider"></div>
        <p class="contact-text">
          Whether you want to attend a performance, enrol in a workshop, invite ATR to 
          your institution, support us as a donor, or collaborate as an artist — 
          we'd love to hear from you.
        </p>

        <div class="contact-ways">
          <div class="contact-way">
            <div class="way-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <h4>Visit Us</h4>
              <p>Actors Academy of Rajasthan<br />Tonk Road, Jaipur, Rajasthan – 302015</p>
            </div>
          </div>

          <div class="contact-way">
            <div class="way-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.86a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16a2 2 0 0 1 .27.92z"/>
              </svg>
            </div>
            <div>
              <h4>Call Us</h4>
              <p><a href="tel:+917821844466" class="contact-link">+91 78218 44466</a></p>
              <p class="sub-note">Mon–Sat, 10 AM – 6 PM</p>
            </div>
          </div>

          <div class="contact-way">
            <div class="way-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <h4>Email Us</h4>
              <p><a href="mailto:contact@actorstheatreatrajasthan.org" class="contact-link">contact@actorstheatreatrajasthan.org</a></p>
              <p><a href="mailto:actorsraj@gmail.com" class="contact-link">actorsraj@gmail.com</a></p>
            </div>
          </div>
        </div>

        <div class="donate-cta">
          <div class="donate-text">
            <h3>Support as a Donor</h3>
            <p>
              As a registered NGO, your donations to Actors Theatre Rajasthan support 
              free community performances, scholarship programmes, and cultural preservation 
              initiatives across Rajasthan.
            </p>
          </div>
          <a href="https://wa.me/917821844466?text=I%20would%20like%20to%20donate" class="btn-donate" target="_blank" rel="noopener">
            Donate to ATR
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="contact-form-wrap animate-in">
        <form class="contact-form" id="contact-form">
          <h3>Send a Message</h3>
          <p class="form-subtitle">We respond to all messages within 2–3 business days.</p>

          <div class="form-group">
            <label for="name">Your Name</label>
            <input type="text" id="name" name="name" placeholder="Full Name" required />
          </div>

          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required />
          </div>

          <div class="form-group">
            <label for="subject">I'm interested in…</label>
            <select id="subject" name="subject">
              <option value="">Select a topic</option>
              <option value="attend">Attending a Performance</option>
              <option value="workshop">Joining a Workshop</option>
              <option value="invite">Inviting ATR to Perform</option>
              <option value="collaborate">Artist Collaboration</option>
              <option value="donate">Making a Donation</option>
              <option value="media">Media / Press</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Tell us more…" required></textarea>
          </div>

          <button type="submit" class="btn-submit">
            Send Message
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="22" y1="2" x2="11" y2="13"/>
              <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact { background: var(--bg-alt); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-text {
    font-size: 0.97rem;
    color: var(--ink-body);
    line-height: 1.9;
    margin-bottom: 2rem;
  }

  .contact-ways { display: flex; flex-direction: column; gap: 1.25rem; margin-bottom: 2.5rem; }

  .contact-way { display: flex; gap: 1rem; align-items: flex-start; }

  .way-icon {
    width: 42px;
    height: 42px;
    background: var(--saffron-pale);
    border: 1px solid var(--border);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--saffron);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .contact-way h4 {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 0.25rem;
    font-family: 'Inter', sans-serif;
  }

  .contact-way p { font-size: 0.85rem; color: var(--ink-body); line-height: 1.6; }
  .contact-link { color: inherit; transition: var(--transition); text-decoration: none; }
  .contact-link:hover { color: var(--saffron); }
  .sub-note { font-size: 0.78rem; color: var(--ink-muted); }

  /* Donate CTA */
  .donate-cta {
    padding: 1.75rem;
    background: linear-gradient(135deg, var(--saffron-pale), var(--bg-warm));
    border: 1px solid var(--border);
    border-radius: 8px;
  }

  .donate-text h3 { font-size: 1.1rem; color: var(--ink); margin-bottom: 0.5rem; }
  .donate-text p { font-size: 0.85rem; color: var(--ink-body); line-height: 1.7; margin-bottom: 1.25rem; }

  .btn-donate {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--saffron);
    color: #FFFFFF;
    padding: 0.75rem 1.75rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    border-radius: 4px;
    transition: var(--transition);
  }

  .btn-donate:hover {
    background: var(--saffron-deep);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(232, 114, 12, 0.3);
  }

  /* Form */
  .contact-form-wrap { position: sticky; top: 6rem; }

  .contact-form {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2.5rem;
    box-shadow: var(--shadow-md);
  }

  .contact-form h3 { font-size: 1.3rem; color: var(--ink); margin-bottom: 0.4rem; }

  .form-subtitle { font-size: 0.82rem; color: var(--ink-muted); margin-bottom: 1.75rem; }

  .form-group { margin-bottom: 1.25rem; }

  .form-group label {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-body);
    margin-bottom: 0.5rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    background: var(--bg-alt);
    border: 1.5px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    color: var(--ink);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    transition: border-color 0.3s ease, background 0.3s ease;
    outline: none;
    -webkit-appearance: none;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder { color: var(--ink-subtle); }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--saffron);
    background: #FFFFFF;
  }

  .form-group textarea { resize: vertical; min-height: 120px; }

  .btn-submit {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--saffron);
    color: #FFFFFF;
    border: none;
    padding: 0.9rem 2rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    border-radius: 6px;
    cursor: pointer;
    transition: var(--transition);
    margin-top: 0.5rem;
  }

  .btn-submit:hover {
    background: var(--saffron-deep);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(232, 114, 12, 0.3);
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
    .contact-form-wrap { position: static; }
  }
</style>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    const form = this as HTMLFormElement;
    const name = (document.getElementById('name') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const subjectSelect = document.getElementById('subject') as HTMLSelectElement;
    const subjectText = subjectSelect.options[subjectSelect.selectedIndex].text;
    const message = (document.getElementById('message') as HTMLTextAreaElement).value;

    // Structure WhatsApp message text
    const waMessage = `*New Message from ATR Website*\n` +
                      `-------------------------------\n` +
                      `👤 *Name:* ${name}\n` +
                      `✉️ *Email:* ${email}\n` +
                      `📌 *Subject:* ${subjectText}\n` +
                      `💬 *Message:* ${message}`;

    // WhatsApp API URL (ATR Phone number: +91 78218 44466)
    const phoneNumber = "917821844466";
    const waUrl = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(waMessage)}`;

    const btn = form.querySelector('.btn-submit') as HTMLButtonElement;
    const originalText = btn.innerHTML;
    
    btn.innerHTML = '✓ Opening WhatsApp...';
    btn.style.background = '#25D366'; // WhatsApp brand green
    btn.disabled = true;

    // Open WhatsApp URL in a new tab
    window.open(waUrl, '_blank');

    setTimeout(() => {
      btn.innerHTML = originalText;
      btn.style.background = '';
      btn.disabled = false;
      form.reset();
    }, 3000);
  });
</script>
