---
---

<header class="navbar" id="navbar">
  <div class="nav-container">
    <a href="/" class="nav-logo">
      <img src="/images/logo.png" alt="Actors Theater at Rajasthan Logo" class="logo-img" />
      <div class="logo-text">
        <span class="logo-main">Actors Theater</span>
        <span class="logo-sub">at Rajasthan</span>
      </div>
    </a>

    <nav class="nav-links" id="nav-links">
      <a href="#about" class="nav-link">About</a>
      <a href="#mission" class="nav-link">Mission</a>
      <a href="#productions" class="nav-link">Productions</a>
      <a href="#rajrangam" class="nav-link">Rajrangam</a>
      <a href="#workshops" class="nav-link">Workshops</a>
      <a href="/press/" class="nav-link">Media Mentions</a>
      <a href="/gallery/" class="nav-link">Gallery</a>
      <a href="/activities/" class="nav-link">Activities</a>
      <a href="/resources/" class="nav-link">Resources</a>
      <a href="#contact" class="nav-link nav-cta">Get Involved</a>
    </nav>

    <button class="hamburger" id="hamburger" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 1.25rem 0;
    transition: var(--transition);
  }

  .navbar.scrolled {
    background: rgba(255, 253, 247, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--border);
    box-shadow: 0 2px 16px rgba(44, 24, 0, 0.08);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .logo-img {
    width: 44px;
    height: 44px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .logo-main {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    /* Default: light (for dark hero) */
    color: rgba(255, 253, 247, 0.92);
    transition: color 0.35s ease;
  }

  /* When scrolled onto light page — switch to dark */
  .navbar.scrolled .logo-main {
    color: var(--ink);
  }

  .logo-sub {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    /* Default: light text for dark hero */
    color: rgba(255, 248, 230, 0.75);
    transition: var(--transition);
    position: relative;
  }

  /* Scrolled: dark text for light bg */
  .navbar.scrolled .nav-link:not(.nav-cta) {
    color: var(--ink-body);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold);
    transition: width 0.3s ease;
  }

  .nav-link:hover {
    color: var(--saffron);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link.nav-cta {
    background: var(--saffron);
    border: 1px solid var(--saffron);
    color: #FFFFFF;
    padding: 0.5rem 1.25rem;
    border-radius: 2px;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
  }

  .nav-link.nav-cta::after {
    display: none;
  }

  .nav-link.nav-cta:hover {
    background: var(--saffron-deep);
    border-color: var(--saffron-deep);
    color: #FFFFFF;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    /* Default: light for dark hero */
    background: rgba(255, 248, 230, 0.85);
    transition: var(--transition);
  }

  /* Scrolled: dark */
  .navbar.scrolled .hamburger span {
    background: var(--ink);
  }

  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }
  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  @media (max-width: 900px) {
    .hamburger { display: flex; }

    .nav-links {
      position: fixed;
      top: 0;
      right: -100%;
      width: min(320px, 85vw);
      height: 100vh;
      background: rgba(255, 253, 247, 0.99);
      backdrop-filter: blur(20px);
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      gap: 1.5rem;
      padding: 2rem;
      transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      border-left: 1px solid var(--border);
      box-shadow: -4px 0 24px rgba(44, 24, 0, 0.1);
    }

    .nav-links.open {
      right: 0;
    }

    .nav-link {
      font-size: 1.1rem;
    }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('nav-links');

  const checkScroll = () => {
    // If not on homepage or scrolled down, add scrolled state
    const isHomepage = window.location.pathname === '/' || window.location.pathname === '/index.html';
    if (window.scrollY > 50 || !isHomepage) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  };

  window.addEventListener('scroll', checkScroll);
  // Run on initial load to ensure subpages render scrolled navbar immediately
  checkScroll();

  // Dynamic path rewriting for subpages
  const isHomepage = window.location.pathname === '/' || window.location.pathname === '/index.html';
  if (!isHomepage) {
    document.querySelectorAll('#nav-links a').forEach(link => {
      const href = link.getAttribute('href');
      if (href && href.startsWith('#')) {
        link.setAttribute('href', '/' + href);
      }
    });
  }

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('active');
    navLinks?.classList.toggle('open');
  });

  navLinks?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('active');
      navLinks?.classList.remove('open');
    });
  });
</script>
