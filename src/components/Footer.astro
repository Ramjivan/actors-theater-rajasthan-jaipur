<footer class="footer">
  <div class="footer-top">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="footer-logo">
            <img src="/images/logo.png" alt="Actors Theater at Rajasthan Logo" class="footer-logo-img" />
            <div>
              <span class="footer-org">Actors Theater at Rajasthan</span>
              <span class="footer-reg">Registered NGO · Est. 1994-95 · Act No. 28 of 1958</span>
            </div>
          </div>
          <p class="footer-tagline">
            Using the transformative power of theatre to illuminate social issues, 
            preserve cultural heritage, and build a more aware and empathetic society.
          </p>
          <div class="footer-socials">
            <a href="https://www.facebook.com/actorsrajasthan" target="_blank" rel="noopener" aria-label="Facebook" class="footer-social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a href="https://www.instagram.com/actorstheatreatrajasthan" target="_blank" rel="noopener" aria-label="Instagram" class="footer-social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
              </svg>
            </a>
            <a href="https://www.youtube.com/@ActorsTheatreRajasthan" target="_blank" rel="noopener" aria-label="YouTube" class="footer-social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="footer-links-col">
          <h4>The Organisation</h4>
          <ul>
            <li><a href="#about">About ATR</a></li>
            <li><a href="/executive-committee/">Executive Committee</a></li>
            <li><a href="#mission">Our Mission</a></li>
            <li><a href="#productions">Productions</a></li>
            <li><a href="#rajrangam">Rajrangam Festival</a></li>
            <li><a href="#workshops">Workshops & Academy</a></li>
            <li><a href="/press/">Media Mentions</a></li>
            <li><a href="/gallery/">Photo Gallery</a></li>
            <li><a href="/activities/">Activities Archive</a></li>
            <li><a href="/resources/">Resource Library</a></li>
          </ul>
        </div>

        <div class="footer-links-col">
          <h4>Get Involved</h4>
          <ul>
            <li><a href="#contact">Attend a Performance</a></li>
            <li><a href="#workshops">Join the Academy</a></li>
            <li><a href="#contact">Collaborate with Us</a></li>
            <li><a href="#contact">Donate & Support</a></li>
            <li><a href="#contact">Invite Us to Perform</a></li>
            <li><a href="#contact">Contact Support</a></li>
          </ul>
        </div>

        <div class="footer-links-col">
          <h4>Supported By</h4>
          <div class="supporters">
            <div class="supporter-item">
              <div class="supporter-dot"></div>
              <span>Ministry of Culture, Govt. of India</span>
            </div>
            <div class="supporter-item">
              <div class="supporter-dot"></div>
              <span>Sangeet Natak Akademi</span>
            </div>
            <div class="supporter-item">
              <div class="supporter-dot"></div>
              <span>Govt. of Rajasthan – Dept. of Art</span>
            </div>
            <div class="supporter-item">
              <div class="supporter-dot"></div>
              <span>Jawahar Kala Kendra, Jaipur</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p class="footer-legal">
        © {new Date().getFullYear()} Actors Theater at Rajasthan. All rights reserved.<br/>
        Registered Non-Governmental Organisation. Reg. No. 28 of 1958 | NGO Darpan ID: RJ/2010/0031456 | FCRA Reg. No. 125560336.
      </p>
      <p class="footer-legal policy-links">
        <a href="/privacy-policy/">Privacy Policy</a> &nbsp;|&nbsp; 
        <a href="/anti-discrimination-policy/">Anti-Discrimination Policy</a>
      </p>
      <p class="footer-craft">
        Built with dedication to the arts.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--charcoal);
    border-top: 1px solid rgba(201, 168, 76, 0.1);
  }

  .footer-top {
    padding: 4rem 0 3rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 3rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .footer-logo-img {
    width: 38px;
    height: 38px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .footer-org {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 0.95rem;
    color: var(--ivory);
    line-height: 1.2;
  }

  .footer-reg {
    display: block;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 2px;
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: rgba(255, 248, 230, 0.72);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .footer-socials {
    display: flex;
    gap: 0.75rem;
  }

  .footer-social-link {
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 248, 230, 0.72);
    transition: var(--transition);
  }

  .footer-social-link:hover {
    background: rgba(201, 168, 76, 0.1);
    border-color: var(--border-subtle);
    color: var(--gold);
    transform: translateY(-2px);
  }

  .footer-links-col h4 {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--saffron-light);
    margin-bottom: 1.25rem;
  }

  .footer-links-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-links-col ul li a {
    font-size: 0.85rem;
    color: rgba(255, 248, 230, 0.72);
    transition: color 0.3s ease;
  }

  .footer-links-col ul li a:hover {
    color: var(--ivory);
  }

  /* Supporters */
  .supporters {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .supporter-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .supporter-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--gold);
    margin-top: 5px;
    flex-shrink: 0;
    opacity: 0.6;
  }

  .supporter-item span {
    font-size: 0.82rem;
    color: rgba(255, 248, 230, 0.72);
    line-height: 1.5;
  }

  /* Footer bottom */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    padding: 1.25rem 0;
  }

  .footer-bottom .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-legal,
  .footer-craft {
    font-size: 0.78rem;
    color: rgba(255, 248, 230, 0.45);
  }

  .policy-links a {
    color: rgba(255, 248, 230, 0.45);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .policy-links a:hover {
    color: var(--primary);
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer-bottom .container {
      justify-content: center;
      text-align: center;
    }
  }
</style>

<script>
  // Dynamic path rewriting for footer links on subpages
  const isHomepage = window.location.pathname === '/' || window.location.pathname === '/index.html';
  if (!isHomepage) {
    document.querySelectorAll('.footer a').forEach(link => {
      const href = link.getAttribute('href');
      if (href && href.startsWith('#')) {
        link.setAttribute('href', '/' + href);
      }
    });
  }
</script>
