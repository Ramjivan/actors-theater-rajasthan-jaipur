---
const actionPhotos = [
  {
    src: "/images/events/traditional_performance_stage.jpeg",
    title: "Gopichand Bhartrihari",
    caption: "Dilip Bhatt's traditional Rajasthani Tamasha musical play on stage."
  },
  {
    src: "/images/events/patriotic_performance_stage.jpeg",
    title: "Patriotic Play Performance",
    caption: "A stirring scene from our patriotic drama honouring freedom fighters."
  },
  {
    src: "/images/events/rehearsal_workshop.jpeg",
    title: "SNA Youth Workshop Rehearsal",
    caption: "Students participating in physical training at the Youth Hostel, Jaipur."
  },
  {
    src: "/images/events/school_workshop_outdoor_1.jpeg",
    title: "Murlipura School Workshop",
    caption: "Dr. Chandradeep Hada directing acting workshop for school children."
  },
  {
    src: "/images/events/school_workshop_outdoor_2.jpeg",
    title: "Ruparampura School Workshop",
    caption: "Teaching acting and folk storytelling to children in Govt. School, Ruparampura."
  },
  {
    src: "/images/events/rajrangam_musical_performance.jpeg",
    title: "7th Rajrangam Showcase",
    caption: "Live musical play presentation at Jawahar Kala Kendra."
  },
  {
    src: "/images/events/masked_theatre_performance.jpeg",
    title: "Mask Theatre Performance",
    caption: "Veer Savarkar play workshop showcase showing masked ensembles."
  }
];

const eventPosters = [
  {
    src: "/images/posters/poster_1.jpeg",
    title: "8th Rajrangam National Festival",
    caption: "Official program schedule poster for the 8th Rajrangam, JKK Jaipur."
  },
  {
    src: "/images/posters/poster_2.jpeg",
    title: "8th Rajrangam Brochure",
    caption: "Festival details and showcase information flyer, Jawahar Kala Kendra."
  },
  {
    src: "/images/posters/poster_3.jpeg",
    title: "2nd Lok Natya Prayogotsav",
    caption: "Sangeet Natak Akademi supported Turrakalangi & Kuchamani Khyal festival."
  },
  {
    src: "/images/posters/poster_7.jpeg",
    title: "7th Rajrangam Poster",
    caption: "Schedule of contemporary plays at JKK from 2nd to 6th January 2025."
  },
  {
    src: "/images/posters/poster_10.jpeg",
    title: "1st Lok Natya Prayogotsav",
    caption: "Posters of the folk showcase including Shiv Mahima and Bheli Bat."
  },
  {
    src: "/images/posters/poster_15.jpeg",
    title: "Vigyan Natak Utsav Poster",
    caption: "Exhibition and play posters organized by Science & Technology Department."
  }
];
---

<section class="media section" id="media">
  <div class="container">
    <div class="media-header animate-in">
      <span class="section-label">Gallery & Recognition</span>
      <h2 class="section-title">When the Stage<br />Tells the Story</h2>
      <div class="gold-divider"></div>
      <p class="section-subtitle">
        A glimpse of our theatrical productions, national recognition, and past campaigns. 
        Click any photo or poster to expand it.
      </p>
    </div>

    <!-- Gallery tabs -->
    <div class="gallery-tabs animate-in">
      <button class="tab-btn active" data-tab="photos">Performance Photos</button>
      <button class="tab-btn" data-tab="posters">Event Posters</button>
    </div>

    <!-- Gallery grid -->
    <div class="gallery-grid animate-in" id="gallery-container">
      <!-- Photos Tab -->
      <div class="gallery-pane active" id="pane-photos">
        <div class="masonry-grid">
          {actionPhotos.map((photo) => (
            <div class="gallery-item" data-src={photo.src} data-title={photo.title} data-caption={photo.caption}>
              <img src={photo.src} alt={photo.title} loading="lazy" />
              <div class="gallery-overlay">
                <span class="zoom-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <polyline points="15 3 21 3 21 9"/>
                    <polyline points="9 21 3 21 3 15"/>
                    <line x1="21" y1="3" x2="14" y2="10"/>
                    <line x1="3" y1="21" x2="10" y2="14"/>
                  </svg>
                </span>
                <h4>{photo.title}</h4>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Posters Tab -->
      <div class="gallery-pane" id="pane-posters">
        <div class="masonry-grid">
          {eventPosters.map((poster) => (
            <div class="gallery-item" data-src={poster.src} data-title={poster.title} data-caption={poster.caption}>
              <img src={poster.src} alt={poster.title} loading="lazy" />
              <div class="gallery-overlay">
                <span class="zoom-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <polyline points="15 3 21 3 21 9"/>
                    <polyline points="9 21 3 21 3 15"/>
                    <line x1="21" y1="3" x2="14" y2="10"/>
                    <line x1="3" y1="21" x2="10" y2="14"/>
                  </svg>
                </span>
                <h4>{poster.title}</h4>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Awards and Social Info Split -->
    <div class="media-layout animate-in">
      <a href="/press" class="media-clipping-link" title="Open Press clippings gallery">
        <div class="media-clipping">
          <div class="clipping-frame">
            <img 
              src="/images/media-clipping.png" 
              alt="Newspaper clipping from Rajasthan Patrika praising ATR workshops" 
              loading="lazy"
            />
            <div class="clipping-hover-overlay">
              <span class="hover-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </span>
              <span>Open Press Archive</span>
            </div>
          </div>
          <div class="clipping-caption">
            <div class="press-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
                <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 0-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/>
                <path d="M18 14h-8M15 18h-5M10 6h8v4h-8V6Z"/>
              </svg>
            </div>
            <div>
              <strong>Rajasthan Patrika & Bhaskar</strong>
              <span>"Click to view 80+ official newspaper reviews and mentions"</span>
            </div>
          </div>
        </div>
      </a>

      <div class="recognitions">
        <h3 class="recog-title">Awards & Recognition</h3>

        <div class="recog-list">
          <div class="recog-item">
            <div class="recog-icon saffron">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                <circle cx="12" cy="8" r="6"/>
                <path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
              </svg>
            </div>
            <div class="recog-content">
              <h4>Ministry of Culture Grants</h4>
              <p>Supported by Ministry of Culture, Govt. of India — for organizing annual Rajrangam Festivals.</p>
              <span class="recog-year">Annual Support</span>
            </div>
          </div>

          <div class="recog-item">
            <div class="recog-icon amber">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            </div>
            <div class="recog-content">
              <h4>Junior Research Fellowship</h4>
              <p>Awarded to Creative Director Dr. Chandradeep Hada for theatre scholarship by MoC.</p>
              <span class="recog-year">Research Recognition</span>
            </div>
          </div>

          <div class="recog-item">
            <div class="recog-icon saffron">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <div class="recog-content">
              <h4>Sangeet Natak Akademi Sanctions</h4>
              <p>Recognized for folk preservation in Turrakalangi, Khyal and Tamasha styles.</p>
              <span class="recog-year">Ongoing Partnerships</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Social follow block -->
    <div class="social-block animate-in">
      <h3>Follow Our Journey</h3>
      <p>Stay updated on upcoming productions, workshops, and festival announcements.</p>
      <div class="social-links">
        <a href="https://www.facebook.com/actorsrajasthan" target="_blank" rel="noopener" class="social-btn facebook">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          <span>actorsrajasthan</span>
        </a>
        <a href="https://www.instagram.com/actorstheatreatrajasthan" target="_blank" rel="noopener" class="social-btn instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
          <span>actorstheatreatrajasthan</span>
        </a>
        <a href="https://www.youtube.com/@ActorsTheatreRajasthan" target="_blank" rel="noopener" class="social-btn youtube">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          <span>YouTube Channel</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Lightbox Modal -->
  <div id="media-lightbox" class="lightbox">
    <button class="lightbox-close" aria-label="Close lightbox">&times;</button>
    <div class="lightbox-wrapper">
      <img id="lightbox-img" src="" alt="" />
      <div class="lightbox-caption">
        <h3 id="lightbox-title"></h3>
        <p id="lightbox-desc"></p>
      </div>
    </div>
  </div>
</section>

<style>
  .media { background: var(--bg-body); }

  .media-header { margin-bottom: 3.5rem; }

  /* Tabs styling */
  .gallery-tabs {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .tab-btn {
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink-muted);
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: var(--transition);
  }

  .tab-btn:hover {
    color: var(--saffron);
  }

  .tab-btn.active {
    color: var(--saffron);
    border-bottom-color: var(--saffron);
  }

  /* Grid Panes */
  .gallery-pane {
    display: none;
  }

  .gallery-pane.active {
    display: block;
  }

  /* Masonry Grid */
  .masonry-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
    margin-bottom: 5rem;
  }

  .gallery-item {
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    aspect-ratio: 4/3;
    border: 1px solid var(--border);
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(44, 24, 0, 0.85) 0%, transparent 60%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .gallery-overlay h4 {
    color: #FFFFFF;
    font-size: 1.05rem;
    margin-top: 0.5rem;
  }

  .zoom-icon {
    align-self: flex-start;
    color: #FFFFFF;
    opacity: 0.8;
  }

  .gallery-item:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-lg);
  }

  .gallery-item:hover img {
    transform: scale(1.05);
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  /* Awards & Recognition layout */
  .media-layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 4rem;
    align-items: start;
    margin-bottom: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .media-clipping-link {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: var(--transition);
  }

  .clipping-frame {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border);
    margin-bottom: 1rem;
    box-shadow: var(--shadow-md);
    position: relative;
  }

  .clipping-hover-overlay {
    position: absolute;
    inset: 0;
    background: rgba(232, 114, 12, 0.9);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: #FFFFFF;
    font-size: 0.9rem;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .media-clipping-link:hover .clipping-hover-overlay {
    opacity: 1;
  }

  .hover-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .clipping-frame img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s ease;
  }

  .clipping-frame:hover img { transform: scale(1.02); }

  .clipping-caption {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: var(--saffron-pale);
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .press-icon { color: var(--saffron); flex-shrink: 0; }

  .clipping-caption div { display: flex; flex-direction: column; gap: 0.2rem; }
  .clipping-caption strong { font-size: 0.9rem; color: var(--ink); }
  .clipping-caption span { font-size: 0.8rem; color: var(--ink-muted); font-style: italic; }

  .recog-title {
    font-size: 1.25rem;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }

  .recog-list { display: flex; flex-direction: column; gap: 1rem; }

  .recog-item {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: var(--transition);
    box-shadow: var(--shadow-sm);
  }

  .recog-item:hover {
    border-color: var(--border-strong);
    box-shadow: var(--shadow-md);
  }

  .recog-icon {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .recog-icon.saffron {
    background: var(--saffron-pale);
    border: 1px solid var(--border);
    color: var(--saffron);
  }

  .recog-icon.amber {
    background: rgba(212, 136, 10, 0.1);
    border: 1px solid rgba(212, 136, 10, 0.2);
    color: var(--amber);
  }

  .recog-content h4 { font-size: 0.9rem; color: var(--ink); margin-bottom: 0.3rem; }
  .recog-content p { font-size: 0.82rem; color: var(--ink-muted); line-height: 1.6; margin-bottom: 0.4rem; }

  .recog-year {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--saffron);
  }

  /* Social block */
  .social-block {
    padding: 2.5rem;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-align: center;
  }

  .social-block h3 { font-size: 1.4rem; color: var(--ink); margin-bottom: 0.5rem; }
  .social-block p { font-size: 0.9rem; color: var(--ink-muted); margin-bottom: 1.5rem; }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.5rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: var(--transition);
    border: 1px solid transparent;
  }

  .social-btn.facebook {
    background: rgba(24, 119, 242, 0.08);
    border-color: rgba(24, 119, 242, 0.2);
    color: #1877f2;
  }
  .social-btn.facebook:hover { background: rgba(24, 119, 242, 0.15); transform: translateY(-2px); }

  .social-btn.instagram {
    background: rgba(228, 64, 95, 0.08);
    border-color: rgba(228, 64, 95, 0.2);
    color: #e4405f;
  }
  .social-btn.instagram:hover { background: rgba(228, 64, 95, 0.15); transform: translateY(-2px); }

  .social-btn.youtube {
    background: rgba(255, 0, 0, 0.06);
    border-color: rgba(255, 0, 0, 0.18);
    color: #ff0000;
  }
  .social-btn.youtube:hover { background: rgba(255, 0, 0, 0.12); transform: translateY(-2px); }

  /* Lightbox Styles */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(44, 24, 0, 0.94);
    backdrop-filter: blur(8px);
    z-index: 2000;
    justify-content: center;
    align-items: center;
    padding: 2rem;
  }

  .lightbox.active {
    display: flex;
  }

  .lightbox-wrapper {
    position: relative;
    max-width: 900px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .lightbox-wrapper img {
    max-width: 100%;
    max-height: 75vh;
    border-radius: 4px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    border: 1px solid rgba(255,255,255,0.1);
  }

  .lightbox-close {
    position: absolute;
    top: 2rem;
    right: 2rem;
    background: transparent;
    border: none;
    color: #FFFDF7;
    font-size: 3rem;
    cursor: pointer;
    line-height: 1;
    transition: var(--transition);
  }

  .lightbox-close:hover {
    color: var(--saffron);
  }

  .lightbox-caption {
    text-align: center;
    color: #FFFDF7;
    max-width: 600px;
  }

  .lightbox-caption h3 {
    font-size: 1.25rem;
    color: var(--saffron-light);
    margin-bottom: 0.5rem;
  }

  .lightbox-caption p {
    font-size: 0.88rem;
    opacity: 0.85;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .media-layout { grid-template-columns: 1fr; gap: 3rem; }
  }
</style>

<script>
  // Tabs switching
  const tabBtns = document.querySelectorAll('.tab-btn');
  const panes = document.querySelectorAll('.gallery-pane');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tabBtns.forEach(b => b.classList.remove('active'));
      panes.forEach(p => p.classList.remove('active'));

      btn.classList.add('active');
      const tabId = btn.getAttribute('data-tab');
      document.getElementById(`pane-${tabId}`)?.classList.add('active');
    });
  });

  // Lightbox functionality
  const lightbox = document.getElementById('media-lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxTitle = document.getElementById('lightbox-title');
  const lightboxDesc = document.getElementById('lightbox-desc');
  const closeBtn = document.querySelector('.lightbox-close');
  const galleryItems = document.querySelectorAll('.gallery-item');

  galleryItems.forEach(item => {
    item.addEventListener('click', () => {
      const src = item.getAttribute('data-src');
      const title = item.getAttribute('data-title');
      const caption = item.getAttribute('data-caption');

      if (src && lightboxImg) {
        lightboxImg.src = src;
        if (lightboxTitle) lightboxTitle.textContent = title || '';
        if (lightboxDesc) lightboxDesc.textContent = caption || '';
        lightbox?.classList.add('active');
        document.body.style.overflow = 'hidden'; // prevent scroll
      }
    });
  });

  // Close lightbox
  const closeLightbox = () => {
    lightbox?.classList.remove('active');
    document.body.style.overflow = '';
    if (lightboxImg) lightboxImg.src = '';
  };

  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      closeLightbox();
    }
  });

  // Escape key to close
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox?.classList.contains('active')) {
      closeLightbox();
    }
  });
</script>
