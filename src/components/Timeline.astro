---

<section class="timeline-section section" id="timeline">
  <div class="container">
    <div class="timeline-header animate-in">
      <span class="section-label">Timeline of Impact</span>
      <h2 class="section-title">Decades of Action,<br />Years of Repertoire</h2>
      <div class="gold-divider"></div>
      <p class="section-subtitle">
        Explore our active archive of stage productions, traditional folk festivals, 
        educational academy workshops, and social awareness campaigns across India and beyond.
      </p>
    </div>

    <!-- Filters -->
    <div class="timeline-filters animate-in">
      <button class="filter-btn active" data-filter="all">All Activities</button>
      <button class="filter-btn" data-filter="production">Stage Plays</button>
      <button class="filter-btn" data-filter="festival">Festivals & Events</button>
      <button class="filter-btn" data-filter="workshop">Workshops & Academy</button>
      <button class="filter-btn" data-filter="campaign">Social Campaigns</button>
    </div>

    <!-- Timeline Grid -->
    <div class="timeline-grid animate-in">
      <div class="timeline-track-line"></div>
      
      {events.map((event) => (
        <div class="timeline-card" data-category={event.category}>
          <div class="timeline-badge-node">
            <span class="badge-year">{event.year}</span>
          </div>
          
          <div class="card-inner">
            {event.image && (
              <div class="card-img-holder">
                <img src={event.image} alt={event.title} loading="lazy" />
              </div>
            )}
            <div class="card-content">
              <span class={`cat-tag tag-${event.category}`}>{event.category}</span>
              <h3>{event.title}</h3>
              <div class="event-meta">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                <span>{event.meta}</span>
              </div>
              <p>{event.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="report-cta animate-in">
      <p>Want a complete report of our activities from 2021 to 2026?</p>
      <a href="/documents/Activities_Report_2021_2026.pdf" target="_blank" class="btn-download">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download Activities Report (PDF)
      </a>
    </div>
  </div>
</section>

<style>
  .timeline-section {
    background: var(--bg-body);
    position: relative;
  }

  .timeline-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .timeline-header .gold-divider {
    margin: 1.5rem auto;
    background: linear-gradient(90deg, transparent, var(--saffron), transparent);
    width: 80px;
  }

  .timeline-header .section-subtitle {
    margin: 0 auto;
    text-align: center;
  }

  /* Filters */
  .timeline-filters {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 4rem;
  }

  .filter-btn {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    color: var(--ink-body);
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.6rem 1.25rem;
    border-radius: 4px;
    cursor: pointer;
    transition: var(--transition);
  }

  .filter-btn:hover,
  .filter-btn.active {
    background: var(--saffron);
    border-color: var(--saffron);
    color: #FFFFFF;
    box-shadow: 0 4px 12px rgba(232, 114, 12, 0.2);
  }

  /* Grid Layout */
  .timeline-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .timeline-track-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 28px;
    width: 1px;
    background: var(--border-strong);
    opacity: 0.4;
    z-index: 0;
  }

  .timeline-card {
    display: flex;
    gap: 2rem;
    position: relative;
    z-index: 1;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .timeline-card.hidden {
    opacity: 0;
    transform: scale(0.95) translateY(10px);
    pointer-events: none;
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
    margin: 0;
    padding: 0;
    gap: 0;
    border: none;
  }

  /* Badge node */
  .timeline-badge-node {
    width: 56px;
    height: 56px;
    background: var(--bg-warm);
    border: 2px solid var(--saffron);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
  }

  .badge-year {
    font-family: 'Playfair Display', serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--saffron);
  }

  /* Card content */
  .card-inner {
    flex-grow: 1;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
  }

  .timeline-card:hover .card-inner {
    border-color: var(--border-strong);
    transform: translateX(4px);
    box-shadow: var(--shadow-md);
  }

  .card-img-holder {
    aspect-ratio: 16/7;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .card-img-holder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-content {
    padding: 1.5rem;
  }

  .cat-tag {
    display: inline-block;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 2px;
    margin-bottom: 0.75rem;
  }

  .tag-production { background: #FDEBD0; color: #E8720C; border: 1px solid rgba(232,114,12,0.15); }
  .tag-festival { background: #E8F8F5; color: #117A65; border: 1px solid rgba(17,122,101,0.15); }
  .tag-workshop { background: #EBF5FB; color: #2980B9; border: 1px solid rgba(41,128,185,0.15); }
  .tag-campaign { background: #F4ECF7; color: #8E44AD; border: 1px solid rgba(142,68,173,0.15); }

  .card-content h3 {
    font-size: 1.15rem;
    color: var(--ink);
    margin-bottom: 0.35rem;
  }

  .event-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--ink-muted);
    margin-bottom: 1rem;
  }

  .event-meta svg {
    color: var(--saffron);
  }

  .card-content p {
    font-size: 0.85rem;
    color: var(--ink-body);
    line-height: 1.7;
  }

  /* CTA */
  .report-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-top: 4rem;
    padding: 2rem;
    background: var(--saffron-pale);
    border: 1px dashed var(--border-strong);
    border-radius: 6px;
    text-align: center;
  }

  .report-cta p {
    font-size: 0.95rem;
    color: var(--ink-body);
    font-weight: 500;
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--saffron);
    color: #FFFFFF;
    padding: 0.75rem 1.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 4px;
    transition: var(--transition);
  }

  .btn-download:hover {
    background: var(--saffron-deep);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(232, 114, 12, 0.2);
  }

  @media (min-width: 650px) {
    .card-inner {
      grid-template-columns: 1fr;
    }
    
    /* If card has image, we show it nicely */
    .timeline-card:has(.card-img-holder) .card-inner {
      grid-template-columns: 35% 1fr;
    }

    .timeline-card:has(.card-img-holder) .card-img-holder {
      aspect-ratio: auto;
      height: 100%;
      border-bottom: none;
      border-right: 1px solid var(--border);
    }
  }

  @media (max-width: 600px) {
    .timeline-track-line { left: 20px; }
    .timeline-badge-node { width: 40px; height: 40px; }
    .badge-year { font-size: 0.75rem; }
    .timeline-card { gap: 1rem; }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.timeline-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Remove active from all
      filterBtns.forEach(b => b.classList.remove('active'));
      // Add active to current
      btn.classList.add('active');

      const filterValue = btn.getAttribute('data-filter');

      cards.forEach(card => {
        const category = card.getAttribute('data-category');
        if (filterValue === 'all' || category === filterValue) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
