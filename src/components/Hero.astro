---
---

<section class="hero" id="hero">
  <div class="hero-bg">
    <div class="hero-slides">
      <div class="hero-slide active" style="background-image: url('/images/events/traditional_performance_stage.jpeg');"></div>
      <div class="hero-slide" style="background-image: url('/images/events/patriotic_performance_stage.jpeg');"></div>
      <div class="hero-slide" style="background-image: url('/images/events/rajrangam_musical_performance.jpeg');"></div>
    </div>
    <div class="hero-overlay"></div>
    <!-- Kesariya saffron glow — patriotic warmth bleeding in from right -->
    <div class="hero-glow"></div>
  </div>

  <!-- Tricolor accent stripe — a nod to Indian national spirit -->
  <div class="tricolor-stripe">
    <span class="tc-saffron"></span>
    <span class="tc-white"></span>
    <span class="tc-green"></span>
  </div>

  <div class="hero-content container">
    <div class="hero-badge animate-in">
      <span class="badge-dot"></span>
      Registered NGO · Since 1995
    </div>

    <h1 class="hero-title animate-in">
      Where Stories<br />
      <em>Transform</em> Society
    </h1>

    <p class="hero-description animate-in">
      Actors Theatre Rajasthan is a cultural force using the power of theatre 
      to illuminate social issues, preserve heritage, and awaken communities 
      across the heartland of India.
    </p>

    <div class="hero-actions animate-in">
      <a href="#productions" class="btn-primary">
        <span>Explore Our Work</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="/donate/" class="btn-ghost">
        Support Our Cause
      </a>
      <a href="#rajrangam" class="btn-ghost" style="opacity: 0.7;">
        Rajrangam Festival
      </a>
    </div>

    <div class="hero-stats animate-in">
      <div class="stat-item">
        <span class="stat-number">25+</span>
        <span class="stat-label">Years of Impact</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">200+</span>
        <span class="stat-label">Productions Staged</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">50K+</span>
        <span class="stat-label">Lives Touched</span>
      </div>
    </div>
  </div>

  <div class="hero-scroll">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* ── Background image ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-slides {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 1.8s ease-in-out;
    /* Brighter background filter to bring out details */
    filter: brightness(0.55) saturate(1.15) sepia(0.12);
  }

  .hero-slide.active {
    opacity: 1;
  }

  /* Primary overlay — softer left side to match the right side brightness while keeping text readable */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(16, 8, 1, 0.65) 0%,
      rgba(20, 10, 2, 0.50) 40%,
      rgba(140, 55, 0, 0.25) 75%,
      rgba(80, 30, 0, 0.15) 100%
    );
  }

  /* Kesariya saffron glow — warm light source from bottom-right */
  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 70% 60% at 80% 90%,
      rgba(232, 114, 12, 0.22) 0%,
      rgba(196, 94, 26, 0.10) 45%,
      transparent 75%
    );
    pointer-events: none;
  }

  /* ── Tricolor stripe ── */
  .tricolor-stripe {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    display: flex;
    flex-direction: column;
    z-index: 2;
  }

  .tricolor-stripe span {
    flex: 1;
  }

  .tc-saffron { background: #FF9933; }
  .tc-white   { background: #FFFFFF; opacity: 0.9; }
  .tc-green   { background: #138808; }

  /* ── Content ── */
  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 6rem;
    padding-bottom: 4rem;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #FFB347;
    border: 1px solid rgba(255, 153, 51, 0.35);
    background: rgba(255, 153, 51, 0.10);
    padding: 0.4rem 1rem;
    border-radius: 2px;
    margin-bottom: 2rem;
    animation: fadeInUp 0.8s ease forwards;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #FF9933;
    animation: shimmer 2s infinite;
  }

  /* Title */
  .hero-title {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 700;
    color: #FFFDF7;
    line-height: 1.05;
    margin-bottom: 1.5rem;
    max-width: 700px;
    animation: fadeInUp 0.8s ease 0.1s both;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.6);
  }

  .hero-title em {
    font-style: italic;
    /* Kesariya gradient on the key word */
    background: linear-gradient(90deg, #FF9933, #FFB347);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Description */
  .hero-description {
    font-size: 1.1rem;
    color: rgba(255, 248, 230, 0.72);
    max-width: 520px;
    line-height: 1.85;
    margin-bottom: 2.5rem;
    animation: fadeInUp 0.8s ease 0.2s both;
  }

  /* Actions */
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 4rem;
    animation: fadeInUp 0.8s ease 0.3s both;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #E8720C;
    color: #FFFFFF;
    padding: 0.9rem 2.2rem;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    border-radius: 3px;
    transition: var(--transition);
    border: 1px solid #E8720C;
  }

  .btn-primary:hover {
    background: #C45E1A;
    border-color: #C45E1A;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(232, 114, 12, 0.45);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    color: rgba(255, 253, 247, 0.85);
    padding: 0.9rem 2rem;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    border-radius: 3px;
    border: 1px solid rgba(255, 253, 247, 0.22);
    transition: var(--transition);
  }

  .btn-ghost:hover {
    border-color: #FF9933;
    color: #FF9933;
    transform: translateY(-2px);
  }

  /* Stats */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
    animation: fadeInUp 0.8s ease 0.4s both;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .stat-number {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: #FF9933;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    /* explicitly white — NOT a theme variable, this section is always dark */
    color: rgba(255, 248, 230, 0.55);
  }

  .stat-divider {
    width: 1px;
    height: 44px;
    background: rgba(255, 153, 51, 0.25);
  }

  /* Scroll indicator */
  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    right: 3rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    z-index: 1;
    opacity: 0.45;
  }

  .hero-scroll span {
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    writing-mode: vertical-rl;
    color: rgba(255, 248, 230, 0.7);
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, #FF9933, transparent);
    animation: scroll-pulse 2s infinite;
  }

  @keyframes scroll-pulse {
    0%   { transform: scaleY(0); transform-origin: top; }
    50%  { transform: scaleY(1); transform-origin: top; }
    51%  { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  @media (max-width: 768px) {
    .hero-scroll { display: none; }
    .hero-stats { gap: 1.5rem; }
    .stat-divider { display: none; }
    .tricolor-stripe { width: 3px; }
  }
</style>

<script>
  // Hero Background Carousel
  const slides = document.querySelectorAll('.hero-slide');
  let currentSlide = 0;
  
  function nextSlide() {
    if (slides.length < 2) return;
    slides[currentSlide].classList.remove('active');
    currentSlide = (currentSlide + 1) % slides.length;
    slides[currentSlide].classList.add('active');
  }

  // Rotate background every 6 seconds
  setInterval(nextSlide, 6000);
</script>
