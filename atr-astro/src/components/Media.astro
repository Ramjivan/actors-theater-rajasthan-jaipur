---

<section class="media section" id="media">
  <div class="container">
    <div class="media-header animate-in">
      <span class="section-label">Press & Recognition</span>
      <h2 class="section-title">When the Stage<br />Makes the Headlines</h2>
      <div class="gold-divider"></div>
      <p class="section-subtitle">
        Our work has earned recognition from national media, government bodies, 
        and cultural institutions. Theatre that matters gets noticed.
      </p>
    </div>

    <div class="media-layout">
      <!-- Newspaper clipping -->
      <div class="media-clipping animate-in">
        <div class="clipping-frame">
          <img 
            src="/images/actors-academy-of-rajasthan-tonk-road-jaipur-a4phb.jpg" 
            alt="Morning Jaipur newspaper: Girl Child's Plight sways Rang Mahotsav" 
            loading="lazy"
          />
        </div>
        <div class="clipping-caption">
          <div class="press-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
              <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 0-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/>
              <path d="M18 14h-8M15 18h-5M10 6h8v4h-8V6Z"/>
            </svg>
          </div>
          <div>
            <strong>Morning Jaipur</strong>
            <span>"Girl Child's Plight sways Rang Mahotsav"</span>
          </div>
        </div>
      </div>

      <!-- Recognition items -->
      <div class="recognitions animate-in">
        <h3 class="recog-title">Awards & Recognition</h3>

        <div class="recog-list">
          <div class="recog-item">
            <div class="recog-icon gold">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                <circle cx="12" cy="8" r="6"/>
                <path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
              </svg>
            </div>
            <div class="recog-content">
              <h4>Ministry of Culture Grant</h4>
              <p>Ministry of Culture, Government of India — for organising Rajrangam, the State Theatre Festival</p>
              <span class="recog-year">Recurring Annual Recognition</span>
            </div>
          </div>

          <div class="recog-item">
            <div class="recog-icon red">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            </div>
            <div class="recog-content">
              <h4>National Media Coverage</h4>
              <p>Featured in Dainik Bhaskar, Rajasthan Patrika, and Morning Jaipur for socially impactful productions</p>
              <span class="recog-year">Multiple Years</span>
            </div>
          </div>

          <div class="recog-item">
            <div class="recog-icon gold">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <div class="recog-content">
              <h4>Sangeet Natak Akademi Collaboration</h4>
              <p>Ongoing artistic and production partnership with India's national academy for music, dance and drama</p>
              <span class="recog-year">Ongoing</span>
            </div>
          </div>

          <div class="recog-item">
            <div class="recog-icon red">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
              </svg>
            </div>
            <div class="recog-content">
              <h4>Participation — Bharat Rang Mahotsav</h4>
              <p>ATR productions selected for India's largest national theatre festival, organised by National School of Drama</p>
              <span class="recog-year">Multiple Editions</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Social media -->
    <div class="social-block animate-in">
      <h3>Follow Our Journey</h3>
      <p>Stay updated on upcoming productions, workshops, and festival announcements.</p>
      <div class="social-links">
        <a href="https://www.facebook.com/actorsrajasthan" target="_blank" rel="noopener" class="social-btn facebook">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          <span>actorsrajasthan</span>
        </a>
        <a href="https://www.instagram.com/actorstheatreatrajasthan" target="_blank" rel="noopener" class="social-btn instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
          <span>actorstheatreatrajasthan</span>
        </a>
        <a href="https://www.youtube.com/@ActorsTheatreRajasthan" target="_blank" rel="noopener" class="social-btn youtube">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          <span>YouTube Channel</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .media {
    background: var(--section-dark);
  }

  .media-header {
    margin-bottom: 3.5rem;
  }

  .media-layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 4rem;
    align-items: start;
    margin-bottom: 4rem;
  }

  /* Clipping */
  .clipping-frame {
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    margin-bottom: 1rem;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }

  .clipping-frame img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s ease;
  }

  .clipping-frame:hover img {
    transform: scale(1.02);
  }

  .clipping-caption {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-subtle);
    border-radius: 4px;
  }

  .press-icon {
    color: var(--gold);
    flex-shrink: 0;
  }

  .clipping-caption div {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .clipping-caption strong {
    font-size: 0.9rem;
    color: var(--ivory);
  }

  .clipping-caption span {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-style: italic;
  }

  /* Recognitions */
  .recog-title {
    font-size: 1.25rem;
    color: var(--ivory);
    margin-bottom: 1.5rem;
  }

  .recog-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .recog-item {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-subtle);
    border-radius: 4px;
    transition: var(--transition);
  }

  .recog-item:hover {
    border-color: rgba(201, 168, 76, 0.2);
    background: rgba(255, 255, 255, 0.04);
  }

  .recog-icon {
    width: 40px;
    height: 40px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .recog-icon.gold {
    background: rgba(201, 168, 76, 0.1);
    border: 1px solid rgba(201, 168, 76, 0.2);
    color: var(--gold);
  }

  .recog-icon.red {
    background: rgba(139, 26, 26, 0.1);
    border: 1px solid rgba(139, 26, 26, 0.2);
    color: var(--crimson-light);
  }

  .recog-content h4 {
    font-size: 0.9rem;
    color: var(--ivory);
    margin-bottom: 0.3rem;
  }

  .recog-content p {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.4rem;
  }

  .recog-year {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold);
  }

  /* Social block */
  .social-block {
    padding: 2.5rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-subtle);
    border-radius: 6px;
    text-align: center;
  }

  .social-block h3 {
    font-size: 1.4rem;
    color: var(--ivory);
    margin-bottom: 0.5rem;
  }

  .social-block p {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.5rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: var(--transition);
    border: 1px solid transparent;
  }

  .social-btn.facebook {
    background: rgba(24, 119, 242, 0.12);
    border-color: rgba(24, 119, 242, 0.25);
    color: #5a9cf5;
  }

  .social-btn.facebook:hover {
    background: rgba(24, 119, 242, 0.2);
    transform: translateY(-2px);
  }

  .social-btn.instagram {
    background: rgba(228, 64, 95, 0.12);
    border-color: rgba(228, 64, 95, 0.25);
    color: #f06090;
  }

  .social-btn.instagram:hover {
    background: rgba(228, 64, 95, 0.2);
    transform: translateY(-2px);
  }

  .social-btn.youtube {
    background: rgba(255, 0, 0, 0.1);
    border-color: rgba(255, 0, 0, 0.2);
    color: #ff6060;
  }

  .social-btn.youtube:hover {
    background: rgba(255, 0, 0, 0.18);
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .media-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
